{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "node dist/packages/backend/src/index.js",
    "restartPolicy": "on-failure",
    "numReplicas": 1,
    "healthchecks": {
      "startup": {
        "interval": 10,
        "timeout": 5,
        "successThreshold": 1,
        "failureThreshold": 3,
        "initialDelaySeconds": 30
      },
      "liveness": {
        "interval": 30,
        "timeout": 10,
        "successThreshold": 1,
        "failureThreshold": 3
      }
    }
  },
  "env": {
    "NODE_ENV": "production",
    "PORT": 3000,
    "LOG_LEVEL": "info"
  }
}
